{
  "name": "demo-vulnerable-app",
  "version": "1.0.0",
  "description": "Intentionally vulnerable demo app for security-autofix pipeline testing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node --check server.js && node --check utils.js",
    "test": "jest --testTimeout=10000 --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "forceExit": true,
    "testMatch": ["**/__tests__/**/*.test.js"],
    "moduleNameMapper": {
      "^marked$": "<rootDir>/__mocks__/marked.js"
    }
  },
  "dependencies": {
    "axios": "0.21.0",
    "ejs": "2.7.4",
    "express": "4.16.0",
    "js-yaml": "3.13.0",
    "jsonwebtoken": "8.3.0",
    "lodash": "4.17.11",
    "marked": "0.3.6",
    "minimist": "0.0.8",
    "moment": "2.26.0",
    "node-forge": "0.9.0",
    "serialize-javascript": "1.7.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
