{
  "name": "demo-vulnerable-app",
  "version": "1.0.0",
  "description": "Intentionally vulnerable demo app for security-autofix pipeline testing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node --check server.js && node --check utils.js",
    "test": "jest --testTimeout=10000 --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "forceExit": true,
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^marked$": "<rootDir>/__mocks__/marked.js"
    }
  },
  "dependencies": {
    "axios": "^1.16.0",
    "ejs": "^5.0.2",
    "express": "^4.22.1",
    "js-yaml": "^3.14.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "marked": "^18.0.3",
    "minimist": "^1.2.8",
    "moment": "^2.30.1",
    "node-forge": "^1.4.0",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
